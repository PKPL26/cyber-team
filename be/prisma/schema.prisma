generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  email     String   @unique
  name      String
  password  String
  desc      String
  major     Major
  birthdate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime
}

enum Major {
  INFORMATION_SYSTEM
  COMPUTER_SCIENCE
}
